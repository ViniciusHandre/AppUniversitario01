<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
    Tema principal da aplicação.
    Herda de Theme.MaterialComponents.DayNight.DarkActionBar para compatibilidade com Material Design.
    -->
    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Cor primária do tema -->
        <item name="colorPrimary">@color/primary</item>
        <!-- Variante mais escura da cor primária -->
        <item name="colorPrimaryVariant">@color/primaryVariant</item>
        <!-- Cor secundária/acentuada -->
        <item name="colorSecondary">@color/secondary</item>
        <!-- Cor da barra de status (topo da tela) -->
        <item name="android:statusBarColor">@color/primaryVariant</item>
    </style>
</resources>