<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!--
    Este é o layout da ContatoActivity.
    Exibe informações de contato fictícias.
    -->

    <!-- Ícone de Contato -->
    <ImageView
        android:id="@+id/ivContact"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@drawable/ic_contact"
        android:contentDescription="Ícone de contato"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- E-mail -->
    <TextView
        android:id="@+id/tvEmail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="email@example.com"
        android:textAppearance="?attr/textAppearanceHeadlineSmall"
        android:textColor="@color/primaryText"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/ivContact"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Telefone -->
    <TextView
        android:id="@+id/tvTelefone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="(00) 00000-0000"
        android:textColor="@color/secondaryText"
        android:layout_marginTop="8dp"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/tvEmail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Redes Sociais -->
    <TextView
        android:id="@+id/tvRedes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@username_univ"
        android:textColor="@color/secondaryText"
        android:layout_marginTop="8dp"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/tvTelefone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Botão Voltar -->
    <Button
        android:id="@+id/btnVoltar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Voltar"
        android:backgroundTint="@color/buttonColorSecondary"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvRedes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

